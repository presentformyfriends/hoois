<h1>Hoois Lookup</h1>
<%= form_tag lookup_path, class: "lookup-form", method: :get do %>
  <%= text_field_tag(:lookup, "", class: "lookup-field", size: 100, maxlength: 255, :placeholder => "Enter a domain (e.g. worldbirds.com)") %>
  <div>
    <%= submit_tag("HOOIS", class: "submit-button") %>
  </div>
<% end %>

<div class="owl-container">
  <div class="eyes-container">
    <div class="eyes"></div>
    <div class="eyes"></div>
  </div>
</div>
